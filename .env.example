# ================================
# HimalayaMart — Environment Variables
# Copy this to .env.local
# ================================

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps (for delivery tracking)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# ================================
# Payment Gateways (set to TEST mode initially)
# ================================

# eSewa (https://developer.esewa.com.np)
NEXT_PUBLIC_ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
NEXT_PUBLIC_ESEWA_ENV=test
# For production: set NEXT_PUBLIC_ESEWA_ENV=live and update keys

# Khalti (https://khalti.com/api/v2/)
NEXT_PUBLIC_KHALTI_PUBLIC_KEY=test_public_key_here
KHALTI_SECRET_KEY=test_secret_key_here
NEXT_PUBLIC_KHALTI_ENV=test
# For production: get from https://khalti.com/merchant/settings/

# IME Pay
NEXT_PUBLIC_IMEPAY_MERCHANT_CODE=your-merchant-code
IMEPAY_MERCHANT_PASSWORD=your-password
NEXT_PUBLIC_IMEPAY_ENV=test

# Fonepay
NEXT_PUBLIC_FONEPAY_MERCHANT_ID=your-merchant-id
FONEPAY_SECRET_KEY=your-secret-key

# ================================
# SMS (Sparrow SMS — https://sparrowsms.com)
# ================================
SPARROW_SMS_TOKEN=your-sparrow-sms-token
SPARROW_SMS_FROM=HimalayaMart
# To enable: uncomment SMS calls in lib/nepal/sms.ts

# ================================
# AI Chat (Gemini)
# ================================
GEMINI_API_KEY=your-gemini-api-key

# ================================
# Commission Settings
# ================================
NEXT_PUBLIC_PLATFORM_COMMISSION_RATE=0.10
NEXT_PUBLIC_MIN_COMMISSION=0.08
NEXT_PUBLIC_MAX_COMMISSION=0.12

# ================================
# Weather / Monsoon Flag
# ================================
OPENWEATHER_API_KEY=your-openweather-key
